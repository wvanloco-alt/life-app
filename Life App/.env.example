# ─── Authentication ────────────────────────────────────────────────────────────
# Required. Random secret used to sign JWT session tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# ─── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file.
# Local dev: leave as default (creates life-app.db in the project root)
# Production (Railway): set to /data/life-app.db and mount a volume at /data
DB_PATH=/data/life-app.db

# ─── Public URL ────────────────────────────────────────────────────────────────
# The public-facing URL of the deployed app. Required for NextAuth redirects.
# Local dev: http://localhost:3000
# Production: https://your-app.up.railway.app
NEXTAUTH_URL=https://your-app.up.railway.app
